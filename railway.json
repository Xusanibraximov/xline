{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "python bot_optimized.py",
    "numReplicas": 1,
    "restartPolicyMaxRetries": -1
  },
  "env": {
    "TELEGRAM_TOKEN": {
      "description": "Telegram Bot Token (@BotFather dan)",
      "required": true
    },
    "ADMIN_CHAT_ID": {
      "description": "Admin Chat ID (@userinfobot dan)",
      "required": true
    },
    "SHEET_ID": {
      "description": "Google Sheets ID (URL dan olib olish)",
      "required": true
    },
    "TIMEZONE": {
      "description": "Timezone (default: Asia/Samarkand)",
      "required": false,
      "default": "Asia/Samarkand"
    }
  }
}
